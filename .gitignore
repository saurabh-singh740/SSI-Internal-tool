# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
# frontend Vite build — output goes to backend/public/ via vite.config.ts outDir
frontend/dist/
# backend/public/ holds the Vite-built frontend; generated by `npm run build`
backend/public/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Uploads / logs ────────────────────────────────────────────────────────────
uploads/
logs/
*.log

# ── Tooling ───────────────────────────────────────────────────────────────────
.claude/

# ── Stray root-level artifacts ────────────────────────────────────────────────
/public/
/vercel.json
