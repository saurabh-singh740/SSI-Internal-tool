# ── Local development ─────────────────────────────────────────────────────────
# Override the Vite proxy target if your backend runs on a different port.
# Defaults to http://localhost:5002 when unset.
VITE_PROXY_TARGET=http://localhost:5002

# ── Separate deployment only (frontend on Vercel/Netlify) ─────────────────────
# Uncomment and set to your Render backend URL if deploying frontend separately.
# When unset the app uses relative /api — correct for unified Render deployment.
# VITE_API_URL=https://your-backend.onrender.com
