# ── Server ────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# ── Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex
JWT_EXPIRES_IN=7d

# ── Email (Resend) ─────────────────────────────────────────
# Sign up at https://resend.com and get your API key
# Verify your sending domain in Resend dashboard → Domains
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The verified sender address (must match your Resend domain)
FROM_EMAIL=noreply@yourdomain.com

# ── Frontend URL (CORS + email links) ─────────────────────
# Production: your Render/Vercel app URL (no trailing slash)
APP_BASE_URL=https://your-app.onrender.com
ALLOWED_ORIGINS=https://your-app.onrender.com

# ── Notes ─────────────────────────────────────────────────
# Do NOT commit the actual .env file.
# On Render: Dashboard → Environment → add each key above.
# Remove EMAIL_USER and EMAIL_PASS — they are no longer used.
