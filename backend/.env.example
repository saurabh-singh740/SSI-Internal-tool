# ── Server ────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# ── Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# ── Email (Gmail App Password) ────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── Frontend URL (CORS + email links) ────────────────────
# Production: replace with your Vercel frontend URL
# Comma-separated list if you have multiple origins (staging, prod, etc.)
APP_BASE_URL=https://your-frontend-name.vercel.app
ALLOWED_ORIGINS=https://your-frontend-name.vercel.app

# ── Vercel deployment notes ───────────────────────────────
# Do NOT commit the actual .env file.
# In Vercel: Project Settings → Environment Variables → add each key above.
# NODE_ENV is set automatically by Vercel to "production".
